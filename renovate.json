{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "timezone": "Europe/London",
  "labels": [
    "dependencies"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^ansible/group_vars/all/main\\.yml$"
      ],
      "matchStrings": [
        "image:\\s+(?<depName>\\S+?):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "docker image updates",
      "groupSlug": "docker-images",
      "rangeStrategy": "pin",
      "automerge": false
    }
  ]
}
