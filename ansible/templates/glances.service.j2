[Unit]
Description=Glances system monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=glances
Group=glances
WorkingDirectory=/etc/glances
ExecStart=/opt/glances-venv/bin/glances -w --bind 0.0.0.0 --port {{ homelab_effective.apps.glances.port }} --enable-mcp -C /etc/glances/glances.conf
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
