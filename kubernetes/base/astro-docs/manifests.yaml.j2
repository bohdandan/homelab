apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.astro_docs.namespace }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: astro-docs
  namespace: {{ homelab_effective.apps.astro_docs.namespace }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: astro-docs
  template:
    metadata:
      labels:
        app: astro-docs
    spec:
      containers:
        - name: astro-docs
          image: {{ homelab_effective.apps.astro_docs.image }}
          ports:
            - containerPort: 80
              name: http
          readinessProbe:
            httpGet:
              path: /
              port: http
          livenessProbe:
            httpGet:
              path: /
              port: http
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 250m
              memory: 256Mi
---
apiVersion: v1
kind: Service
metadata:
  name: astro-docs
  namespace: {{ homelab_effective.apps.astro_docs.namespace }}
spec:
  selector:
    app: astro-docs
  ports:
    - name: http
      port: 80
      targetPort: 80
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: astro-docs
  namespace: {{ homelab_effective.apps.astro_docs.namespace }}
  annotations:
    cert-manager.io/cluster-issuer: "{{ homelab_effective.cert_manager.cluster_issuer_name }}"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - {{ homelab_effective.domain.docs }}
        - {{ homelab_effective.domain.docs_internal }}
      secretName: homelab-wildcard-tls
  rules:
    - host: {{ homelab_effective.domain.docs }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: astro-docs
                port:
                  number: 80
    - host: {{ homelab_effective.domain.docs_internal }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: astro-docs
                port:
                  number: 80
