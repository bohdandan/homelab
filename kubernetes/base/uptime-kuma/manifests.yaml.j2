apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.uptime_kuma.namespace }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: uptime-kuma-data
  namespace: {{ homelab_effective.apps.uptime_kuma.namespace }}
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: local-path
  resources:
    requests:
      storage: {{ homelab_effective.apps.uptime_kuma.data_storage }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: uptime-kuma
  namespace: {{ homelab_effective.apps.uptime_kuma.namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: uptime-kuma
  template:
    metadata:
      labels:
        app: uptime-kuma
    spec:
      nodeSelector:
        homelab.io/stateful: "true"
      containers:
        - name: uptime-kuma
          image: {{ homelab_effective.apps.uptime_kuma.image }}
          ports:
            - containerPort: 3001
              name: http
          readinessProbe:
            tcpSocket:
              port: http
          livenessProbe:
            tcpSocket:
              port: http
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 1000m
              memory: 1Gi
          volumeMounts:
            - name: uptime-kuma-data
              mountPath: /app/data
      volumes:
        - name: uptime-kuma-data
          persistentVolumeClaim:
            claimName: uptime-kuma-data
---
apiVersion: v1
kind: Service
metadata:
  name: uptime-kuma
  namespace: {{ homelab_effective.apps.uptime_kuma.namespace }}
spec:
  selector:
    app: uptime-kuma
  ports:
    - name: http
      port: 3001
      targetPort: 3001
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: uptime-kuma
  namespace: {{ homelab_effective.apps.uptime_kuma.namespace }}
  annotations:
    cert-manager.io/cluster-issuer: "{{ homelab_effective.cert_manager.cluster_issuer_name }}"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - {{ homelab_effective.domain.kuma }}
      secretName: homelab-wildcard-tls
  rules:
    - host: {{ homelab_effective.domain.kuma }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: uptime-kuma
                port:
                  number: 3001
