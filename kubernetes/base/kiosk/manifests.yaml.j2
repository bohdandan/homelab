apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.kiosk.namespace }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: kiosk-config
  namespace: {{ homelab_effective.apps.kiosk.namespace }}
data:
  dashboard.json: |
{{ lookup('ansible.builtin.file', playbook_dir ~ '/../../apps/kiosk/config/dashboard.json') | indent(4, true) }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: kiosk
  namespace: {{ homelab_effective.apps.kiosk.namespace }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: kiosk
  template:
    metadata:
      labels:
        app: kiosk
    spec:
      containers:
        - name: kiosk
          image: {{ homelab_effective.apps.kiosk.image }}
          ports:
            - containerPort: 80
              name: http
          volumeMounts:
            - name: config
              mountPath: /usr/share/nginx/html/config/dashboard.json
              subPath: dashboard.json
              readOnly: true
          readinessProbe:
            httpGet:
              path: /
              port: http
          livenessProbe:
            httpGet:
              path: /
              port: http
          resources:
            requests:
              cpu: 50m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
      volumes:
        - name: config
          configMap:
            name: kiosk-config
---
apiVersion: v1
kind: Service
metadata:
  name: kiosk
  namespace: {{ homelab_effective.apps.kiosk.namespace }}
spec:
  selector:
    app: kiosk
  ports:
    - name: http
      port: 80
      targetPort: 80
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: kiosk
  namespace: {{ homelab_effective.apps.kiosk.namespace }}
  annotations:
    cert-manager.io/cluster-issuer: "{{ homelab_effective.cert_manager.cluster_issuer_name }}"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - {{ homelab_effective.domain.kiosk }}
      secretName: homelab-wildcard-tls
  rules:
    - host: {{ homelab_effective.domain.kiosk }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: kiosk
                port:
                  number: 80
