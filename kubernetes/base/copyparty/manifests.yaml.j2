{% set copyparty_rendered_config = lookup("template", playbook_dir ~ "/../../apps/copyparty/copyparty.conf.j2") %}
apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.copyparty.namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: copyparty-config
  namespace: {{ homelab_effective.apps.copyparty.namespace }}
type: Opaque
stringData:
  copyparty.conf: |
{{ copyparty_rendered_config | indent(4, true) }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: copyparty
  namespace: {{ homelab_effective.apps.copyparty.namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: copyparty
  template:
    metadata:
      annotations:
        checksum/copyparty-config: "{{ copyparty_rendered_config | hash('sha256') }}"
      labels:
        app: copyparty
    spec:
      nodeSelector:
        homelab.io/stateful: "true"
        kubernetes.io/hostname: {{ homelab_effective.k3s.worker.name }}
      containers:
        - name: copyparty
          image: {{ homelab_effective.apps.copyparty.image }}
          args:
            - -c
            - /etc/copyparty/copyparty.conf
            - -i
            - 0.0.0.0
            - -p
            - "3923"
          ports:
            - containerPort: 3923
              name: http
          readinessProbe:
            tcpSocket:
              port: http
          livenessProbe:
            tcpSocket:
              port: http
          resources:
            requests:
              cpu: 250m
              memory: 512Mi
            limits:
              cpu: 1000m
              memory: 2Gi
          volumeMounts:
            - name: copyparty-config
              mountPath: /etc/copyparty/copyparty.conf
              subPath: copyparty.conf
              readOnly: true
            - name: copyparty-share
              mountPath: /srv/share
            - name: copyparty-ingest
              mountPath: /srv/ingest
              readOnly: true
            # Hide the ext4 maintenance directory from the removable ingest disk.
            - name: copyparty-ingest-lost-found-shadow
              mountPath: /srv/ingest/lost+found
              readOnly: true
      volumes:
        - name: copyparty-config
          secret:
            secretName: copyparty-config
        - name: copyparty-share
          hostPath:
            path: {{ homelab_effective.storage.copyparty_share.mount_path }}
            type: Directory
        - name: copyparty-ingest
          hostPath:
            path: {{ homelab_effective.storage.copyparty_ingest.worker_mount_path }}
            type: Directory
        - name: copyparty-ingest-lost-found-shadow
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: copyparty
  namespace: {{ homelab_effective.apps.copyparty.namespace }}
spec:
  selector:
    app: copyparty
  ports:
    - name: http
      port: 80
      targetPort: http
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: copyparty
  namespace: {{ homelab_effective.apps.copyparty.namespace }}
  annotations:
    cert-manager.io/cluster-issuer: "{{ homelab_effective.cert_manager.cluster_issuer_name }}"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - {{ homelab_effective.domain.share }}
        - {{ homelab_effective.domain.share_internal }}
      secretName: homelab-wildcard-tls
  rules:
    - host: {{ homelab_effective.domain.share }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: copyparty
                port:
                  number: 80
    - host: {{ homelab_effective.domain.share_internal }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: copyparty
                port:
                  number: 80
