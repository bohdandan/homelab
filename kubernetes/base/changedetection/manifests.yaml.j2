apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.changedetection.namespace }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: changedetection-data
  namespace: {{ homelab_effective.apps.changedetection.namespace }}
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: local-path
  resources:
    requests:
      storage: {{ homelab_effective.apps.changedetection.data_storage }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: changedetection
  namespace: {{ homelab_effective.apps.changedetection.namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: changedetection
  template:
    metadata:
      labels:
        app: changedetection
    spec:
      nodeSelector:
        homelab.io/stateful: "true"
      containers:
        - name: changedetection
          image: {{ homelab_effective.apps.changedetection.image }}
          env:
            - name: BASE_URL
              value: "https://{{ homelab_effective.domain.changedetection }}"
            - name: TZ
              value: UTC
          ports:
            - containerPort: 5000
              name: http
          readinessProbe:
            httpGet:
              path: /
              port: http
          livenessProbe:
            httpGet:
              path: /
              port: http
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 1000m
              memory: 1Gi
          volumeMounts:
            - name: changedetection-data
              mountPath: /datastore
      volumes:
        - name: changedetection-data
          persistentVolumeClaim:
            claimName: changedetection-data
---
apiVersion: v1
kind: Service
metadata:
  name: changedetection
  namespace: {{ homelab_effective.apps.changedetection.namespace }}
spec:
  selector:
    app: changedetection
  ports:
    - name: http
      port: 5000
      targetPort: 5000
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: changedetection
  namespace: {{ homelab_effective.apps.changedetection.namespace }}
  annotations:
    cert-manager.io/cluster-issuer: "{{ homelab_effective.cert_manager.cluster_issuer_name }}"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - {{ homelab_effective.domain.changedetection }}
      secretName: homelab-wildcard-tls
  rules:
    - host: {{ homelab_effective.domain.changedetection }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: changedetection
                port:
                  number: 5000
