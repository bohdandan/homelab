apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.cloudflared.namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: tunnel-token
  namespace: {{ homelab_effective.apps.cloudflared.namespace }}
type: Opaque
stringData:
  token: {{ homelab_effective.secrets.cloudflare_tunnel_token | quote }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: cloudflared
  namespace: {{ homelab_effective.apps.cloudflared.namespace }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: cloudflared
  template:
    metadata:
      labels:
        app: cloudflared
    spec:
      containers:
        - name: cloudflared
          image: {{ homelab_effective.apps.cloudflared.image }}
          args:
            - tunnel
            - --no-autoupdate
            - run
            - --token
            - $(TUNNEL_TOKEN)
          env:
            - name: TUNNEL_TOKEN
              valueFrom:
                secretKeyRef:
                  name: tunnel-token
                  key: token
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 250m
              memory: 256Mi
