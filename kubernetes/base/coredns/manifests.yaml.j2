apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.coredns.namespace }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: coredns
  namespace: {{ homelab_effective.apps.coredns.namespace }}
data:
  Corefile: |
    .:53 {
        errors
        health :8080
        ready :8181
        file /etc/coredns/db.homelab {{ homelab_effective.domain.subzone }}
        forward . {{ homelab_effective.apps.coredns.upstream_resolver }}
        cache 30
        reload
        loadbalance
    }
  db.homelab: |
    $ORIGIN {{ homelab_effective.domain.subzone }}.
    @ 3600 IN SOA ns1.{{ homelab_effective.domain.subzone }}. admin.{{ homelab_effective.domain.root }}. (
      2026032603
      7200
      3600
      1209600
      3600
    )
    @ 3600 IN NS ns1.{{ homelab_effective.domain.subzone }}.
    ns1 3600 IN A {{ homelab_effective.apps.coredns.service_ip }}
    ha 300 IN A {{ homelab_effective.network.traefik_lb_ip }}
    homepage 300 IN A {{ homelab_effective.network.traefik_lb_ip }}
    n8n 300 IN A {{ homelab_effective.network.traefik_lb_ip }}
    share 300 IN A {{ homelab_effective.network.traefik_lb_ip }}
    traefik 300 IN A {{ homelab_effective.network.traefik_lb_ip }}
    dev 300 IN A {{ homelab_effective.dev_admin.ip }}
    proxmox 300 IN A {{ homelab_effective.proxmox.ssh_host }}
    haos 300 IN A {{ homelab_effective.haos.desired_ip }}
    k3s-control 300 IN A {{ homelab_effective.k3s.control.ip }}
    k3s-worker 300 IN A {{ homelab_effective.k3s.worker.ip }}
    * 300 IN A {{ homelab_effective.network.traefik_lb_ip }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: coredns
  namespace: {{ homelab_effective.apps.coredns.namespace }}
spec:
  replicas: 2
  selector:
    matchLabels:
      app: coredns
  template:
    metadata:
      labels:
        app: coredns
    spec:
      affinity:
        podAntiAffinity:
          preferredDuringSchedulingIgnoredDuringExecution:
            - weight: 100
              podAffinityTerm:
                labelSelector:
                  matchLabels:
                    app: coredns
                topologyKey: kubernetes.io/hostname
      containers:
        - name: coredns
          image: {{ homelab_effective.apps.coredns.image }}
          args:
            - -conf
            - /etc/coredns/Corefile
          ports:
            - name: dns-udp
              containerPort: 53
              protocol: UDP
            - name: dns-tcp
              containerPort: 53
              protocol: TCP
            - name: metrics
              containerPort: 9153
              protocol: TCP
            - name: health
              containerPort: 8080
              protocol: TCP
            - name: ready
              containerPort: 8181
              protocol: TCP
          livenessProbe:
            httpGet:
              path: /health
              port: health
          readinessProbe:
            httpGet:
              path: /ready
              port: ready
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 250m
              memory: 256Mi
          volumeMounts:
            - name: config
              mountPath: /etc/coredns
      volumes:
        - name: config
          configMap:
            name: coredns
---
apiVersion: v1
kind: Service
metadata:
  name: coredns
  namespace: {{ homelab_effective.apps.coredns.namespace }}
spec:
  type: LoadBalancer
  loadBalancerIP: {{ homelab_effective.apps.coredns.service_ip }}
  selector:
    app: coredns
  ports:
    - name: dns-udp
      port: 53
      targetPort: 53
      protocol: UDP
    - name: dns-tcp
      port: 53
      targetPort: 53
      protocol: TCP
