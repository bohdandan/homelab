apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ homelab_effective.cert_manager.cluster_issuer_name }}
spec:
  acme:
    email: {{ homelab_effective.cert_manager.email }}
    server: https://acme-v02.api.letsencrypt.org/directory
    privateKeySecretRef:
      name: {{ homelab_effective.cert_manager.private_key_secret_name }}
    solvers:
      - dns01:
          cloudflare:
            apiTokenSecretRef:
              name: cloudflare-api-token
              key: api-token
