apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.quickdrop.namespace }}
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: quickdrop-metadata
  namespace: {{ homelab_effective.apps.quickdrop.namespace }}
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: local-path
  resources:
    requests:
      storage: {{ homelab_effective.apps.quickdrop.metadata_storage }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: quickdrop
  namespace: {{ homelab_effective.apps.quickdrop.namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: quickdrop
  template:
    metadata:
      labels:
        app: quickdrop
    spec:
      nodeSelector:
        homelab.io/stateful: "true"
        kubernetes.io/hostname: {{ homelab_effective.k3s.worker.name }}
      containers:
        - name: quickdrop
          image: {{ homelab_effective.apps.quickdrop.image }}
          ports:
            - containerPort: 8080
              name: http
          livenessProbe:
            tcpSocket:
              port: http
          readinessProbe:
            tcpSocket:
              port: http
          resources:
            requests:
              cpu: 250m
              memory: 256Mi
            limits:
              cpu: 1000m
              memory: 1Gi
          volumeMounts:
            - name: quickdrop-metadata
              mountPath: /app/db
              subPath: db
            - name: quickdrop-share-files
              mountPath: /app/files
            - name: quickdrop-metadata
              mountPath: /app/log
              subPath: log
      volumes:
        - name: quickdrop-metadata
          persistentVolumeClaim:
            claimName: quickdrop-metadata
        - name: quickdrop-share-files
          hostPath:
            path: {{ homelab_effective.apps.quickdrop.files_host_path }}
            type: DirectoryOrCreate
---
apiVersion: v1
kind: Service
metadata:
  name: quickdrop
  namespace: {{ homelab_effective.apps.quickdrop.namespace }}
spec:
  selector:
    app: quickdrop
  ports:
    - name: http
      port: 8080
      targetPort: 8080
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: quickdrop
  namespace: {{ homelab_effective.apps.quickdrop.namespace }}
  annotations:
    cert-manager.io/cluster-issuer: "{{ homelab_effective.cert_manager.cluster_issuer_name }}"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - {{ homelab_effective.domain.share }}
        - {{ homelab_effective.domain.share_internal }}
      secretName: homelab-wildcard-tls
  rules:
    - host: {{ homelab_effective.domain.share }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: quickdrop
                port:
                  number: 8080
    - host: {{ homelab_effective.domain.share_internal }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: quickdrop
                port:
                  number: 8080
