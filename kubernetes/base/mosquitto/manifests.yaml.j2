apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.mosquitto.namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: mosquitto-auth
  namespace: {{ homelab_effective.apps.mosquitto.namespace }}
type: Opaque
stringData:
  MQTT_USERNAME: {{ homelab_effective.secrets.mqtt_username | quote }}
  MQTT_PASSWORD: {{ homelab_effective.secrets.mqtt_password | quote }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: mosquitto-config
  namespace: {{ homelab_effective.apps.mosquitto.namespace }}
data:
  mosquitto.conf: |
    listener 1883
    allow_anonymous false
    password_file /mosquitto/generated/passwordfile
    persistence true
    persistence_location /mosquitto/data/
    autosave_interval 1800
    log_dest stdout
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: mosquitto-data
  namespace: {{ homelab_effective.apps.mosquitto.namespace }}
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: local-path
  resources:
    requests:
      storage: {{ homelab_effective.apps.mosquitto.data_storage }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: mosquitto
  namespace: {{ homelab_effective.apps.mosquitto.namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: mosquitto
  template:
    metadata:
      labels:
        app: mosquitto
    spec:
      nodeSelector:
        homelab.io/stateful: "true"
      initContainers:
        - name: generate-passwordfile
          image: {{ homelab_effective.apps.mosquitto.image }}
          command:
            - /bin/sh
            - -ec
            - |
              mosquitto_passwd -b -c /mosquitto/generated/passwordfile "$MQTT_USERNAME" "$MQTT_PASSWORD"
              chown mosquitto:mosquitto /mosquitto/generated/passwordfile
              chmod 0600 /mosquitto/generated/passwordfile
          envFrom:
            - secretRef:
                name: mosquitto-auth
          volumeMounts:
            - name: generated
              mountPath: /mosquitto/generated
      containers:
        - name: mosquitto
          image: {{ homelab_effective.apps.mosquitto.image }}
          args:
            - /usr/sbin/mosquitto
            - -c
            - /mosquitto/config/mosquitto.conf
          ports:
            - containerPort: 1883
              name: mqtt
          livenessProbe:
            tcpSocket:
              port: mqtt
          readinessProbe:
            tcpSocket:
              port: mqtt
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
          volumeMounts:
            - name: config
              mountPath: /mosquitto/config
            - name: generated
              mountPath: /mosquitto/generated
            - name: data
              mountPath: /mosquitto/data
      volumes:
        - name: config
          configMap:
            name: mosquitto-config
        - name: generated
          emptyDir: {}
        - name: data
          persistentVolumeClaim:
            claimName: mosquitto-data
---
apiVersion: v1
kind: Service
metadata:
  name: mosquitto
  namespace: {{ homelab_effective.apps.mosquitto.namespace }}
spec:
  type: LoadBalancer
  loadBalancerIP: {{ homelab_effective.apps.mosquitto.service_ip }}
  selector:
    app: mosquitto
  ports:
    - name: mqtt
      port: 1883
      targetPort: 1883
      protocol: TCP
