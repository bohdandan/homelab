apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.ntfy.namespace }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: ntfy-config
  namespace: {{ homelab_effective.apps.ntfy.namespace }}
data:
  server.yml: |
    base-url: "https://{{ homelab_effective.domain.ntfy }}"
    listen-http: ":80"
    behind-proxy: true
    cache-file: "/var/cache/ntfy/cache.db"
    attachment-cache-dir: "/var/cache/ntfy/attachments"
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: ntfy-data
  namespace: {{ homelab_effective.apps.ntfy.namespace }}
spec:
  accessModes:
    - ReadWriteOnce
  storageClassName: local-path
  resources:
    requests:
      storage: {{ homelab_effective.apps.ntfy.data_storage }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: ntfy
  namespace: {{ homelab_effective.apps.ntfy.namespace }}
spec:
  replicas: 1
  strategy:
    type: Recreate
  selector:
    matchLabels:
      app: ntfy
  template:
    metadata:
      labels:
        app: ntfy
    spec:
      nodeSelector:
        homelab.io/stateful: "true"
      containers:
        - name: ntfy
          image: {{ homelab_effective.apps.ntfy.image }}
          args:
            - serve
            - --config
            - /etc/ntfy/server.yml
          ports:
            - containerPort: 80
              name: http
          readinessProbe:
            httpGet:
              path: /v1/health
              port: http
          livenessProbe:
            httpGet:
              path: /v1/health
              port: http
          resources:
            requests:
              cpu: 50m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
          volumeMounts:
            - name: config
              mountPath: /etc/ntfy/server.yml
              subPath: server.yml
            - name: ntfy-data
              mountPath: /var/cache/ntfy
      volumes:
        - name: config
          configMap:
            name: ntfy-config
        - name: ntfy-data
          persistentVolumeClaim:
            claimName: ntfy-data
---
apiVersion: v1
kind: Service
metadata:
  name: ntfy
  namespace: {{ homelab_effective.apps.ntfy.namespace }}
spec:
  selector:
    app: ntfy
  ports:
    - name: http
      port: 80
      targetPort: 80
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ntfy
  namespace: {{ homelab_effective.apps.ntfy.namespace }}
  annotations:
    cert-manager.io/cluster-issuer: "{{ homelab_effective.cert_manager.cluster_issuer_name }}"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - {{ homelab_effective.domain.ntfy }}
      secretName: homelab-wildcard-tls
  rules:
    - host: {{ homelab_effective.domain.ntfy }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: ntfy
                port:
                  number: 80
