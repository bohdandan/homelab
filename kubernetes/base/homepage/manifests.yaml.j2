apiVersion: v1
kind: Namespace
metadata:
  name: {{ homelab_effective.apps.homepage.namespace }}
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: homepage-config
  namespace: {{ homelab_effective.apps.homepage.namespace }}
data:
  settings.yaml: |
    title: Homelab
    theme: dark
    color: slate
    hideVersion: true
  bookmarks.yaml: |
    []
  custom.css: |
  custom.js: |
  services.yaml: |
    - Apps:
        - Docs:
            href: https://{{ homelab_effective.domain.docs_internal }}
            siteMonitor: https://{{ homelab_effective.domain.docs_internal }}/
            description: Homelab documentation
            namespace: {{ homelab_effective.apps.astro_docs.namespace }}
            podSelector: app=astro-docs
        - QuickDrop:
            href: https://{{ homelab_effective.domain.share_internal }}
            siteMonitor: https://{{ homelab_effective.domain.share_internal }}/
            description: Large file sharing
            namespace: {{ homelab_effective.apps.quickdrop.namespace }}
            podSelector: app=quickdrop
        - n8n:
            href: https://{{ homelab_effective.domain.n8n_internal }}
            siteMonitor: https://{{ homelab_effective.domain.n8n_internal }}/
            description: Automation workflows
            namespace: {{ homelab_effective.apps.n8n.namespace }}
            podSelector: app=n8n
        - Home Assistant:
            href: https://{{ homelab_effective.domain.home_assistant }}
            siteMonitor: https://{{ homelab_effective.domain.home_assistant }}/
            description: Smart home
        - Zigbee2MQTT:
            href: https://{{ homelab_effective.domain.zigbee }}
            siteMonitor: https://{{ homelab_effective.domain.zigbee }}/
            description: Zigbee coordinator UI
            namespace: {{ homelab_effective.apps.zigbee2mqtt.namespace }}
            podSelector: app=zigbee2mqtt
    - Observability:
        - ChangeDetection:
            href: https://{{ homelab_effective.domain.changedetection }}
            siteMonitor: https://{{ homelab_effective.domain.changedetection }}/
            description: Website change monitoring
            namespace: {{ homelab_effective.apps.changedetection.namespace }}
            podSelector: app=changedetection
        - Uptime Kuma:
            href: https://{{ homelab_effective.domain.kuma }}
            siteMonitor: https://{{ homelab_effective.domain.kuma }}/
            description: Service uptime checks
            namespace: {{ homelab_effective.apps.uptime_kuma.namespace }}
            podSelector: app=uptime-kuma
        - ntfy:
            href: https://{{ homelab_effective.domain.ntfy }}
            siteMonitor: https://{{ homelab_effective.domain.ntfy }}/
            description: Internal notifications
            namespace: {{ homelab_effective.apps.ntfy.namespace }}
            podSelector: app=ntfy
        - Glances:
            href: https://{{ homelab_effective.domain.glances }}
            siteMonitor: http://{{ homelab_effective.dev_admin.ip }}:{{ homelab_effective.apps.glances.port }}/api/4/all
            widget:
              type: glances
              url: http://{{ homelab_effective.dev_admin.ip }}:{{ homelab_effective.apps.glances.port }}
              version: 4
              metric: info
    - Database:
        - Postgres:
            description: n8n database
            namespace: {{ homelab_effective.apps.postgres.namespace }}
            podSelector: app=postgres
        - CloudBeaver:
            href: https://{{ homelab_effective.domain.cloudbeaver }}
            siteMonitor: https://{{ homelab_effective.domain.cloudbeaver }}/
            description: Internal database UI
            namespace: {{ homelab_effective.apps.cloudbeaver.namespace }}
            podSelector: app=cloudbeaver
    - Platform:
        - Proxmox:
            href: https://{{ homelab_effective.domain.proxmox }}:8006
            description: Virtualization host
        - Traefik:
            description: Ingress controller
            namespace: kube-system
            podSelector: app.kubernetes.io/name=traefik
        - Cloudflare Tunnels:
            description: Cloudflare tunnel connector
            namespace: {{ homelab_effective.apps.cloudflared.namespace }}
            podSelector: app=cloudflared
        - CoreDNS:
            description: LAN DNS service
            namespace: {{ homelab_effective.apps.coredns.namespace }}
            podSelector: app=coredns
  widgets.yaml: |
    - datetime:
        text_size: xl
        format:
          dateStyle: short
          timeStyle: short
    - kubernetes:
        cluster:
          show: true
          cpu: true
          memory: true
          showLabel: true
          label: cluster
        nodes:
          show: true
          cpu: true
          memory: true
          showLabel: true
          label: nodes
  kubernetes.yaml: |
    mode: cluster
  docker.yaml: |
    {}
  proxmox.yaml: |
    {}
---
apiVersion: v1
kind: ServiceAccount
metadata:
  name: homepage
  namespace: {{ homelab_effective.apps.homepage.namespace }}
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRole
metadata:
  name: homepage
rules:
  - apiGroups: [""]
    resources: ["namespaces", "nodes", "pods", "services"]
    verbs: ["get", "list"]
  - apiGroups: ["networking.k8s.io"]
    resources: ["ingresses"]
    verbs: ["get", "list"]
  - apiGroups: ["metrics.k8s.io"]
    resources: ["nodes", "pods"]
    verbs: ["get", "list"]
---
apiVersion: rbac.authorization.k8s.io/v1
kind: ClusterRoleBinding
metadata:
  name: homepage
roleRef:
  apiGroup: rbac.authorization.k8s.io
  kind: ClusterRole
  name: homepage
subjects:
  - kind: ServiceAccount
    name: homepage
    namespace: {{ homelab_effective.apps.homepage.namespace }}
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: homepage
  namespace: {{ homelab_effective.apps.homepage.namespace }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: homepage
  template:
    metadata:
      labels:
        app: homepage
    spec:
      serviceAccountName: homepage
      containers:
        - name: homepage
          image: {{ homelab_effective.apps.homepage.image }}
          env:
            - name: HOMEPAGE_ALLOWED_HOSTS
              value: "{{ homelab_effective.domain.homepage }},{{ homelab_effective.domain.homepage_internal }}"
          ports:
            - containerPort: 3000
              name: http
          volumeMounts:
            - name: config
              mountPath: /app/config
            - name: logs
              mountPath: /app/config/logs
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi
      volumes:
        - name: config
          configMap:
            name: homepage-config
        - name: logs
          emptyDir: {}
---
apiVersion: v1
kind: Service
metadata:
  name: homepage
  namespace: {{ homelab_effective.apps.homepage.namespace }}
spec:
  selector:
    app: homepage
  ports:
    - name: http
      port: 3000
      targetPort: 3000
---
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: homepage
  namespace: {{ homelab_effective.apps.homepage.namespace }}
  annotations:
    cert-manager.io/cluster-issuer: "{{ homelab_effective.cert_manager.cluster_issuer_name }}"
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - {{ homelab_effective.domain.homepage }}
        - {{ homelab_effective.domain.homepage_internal }}
      secretName: homelab-wildcard-tls
  rules:
    - host: {{ homelab_effective.domain.homepage }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: homepage
                port:
                  number: 3000
    - host: {{ homelab_effective.domain.homepage_internal }}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: homepage
                port:
                  number: 3000
